# RSSHub deployment environment variables
# Copy to .env and adjust as needed.

# Optional: set an access key to protect your RSSHub instance.
# If set, all requests must include ?key=<value> or header Access-Key.
# Leave empty for open access (internal network only).
RSSHUB_ACCESS_KEY=

# Example: restrict to known routes only (comma-separated)
# ALLOWLIST=/reuters/,/bbc/,/nytimes/,/theguardian/,/customs/
