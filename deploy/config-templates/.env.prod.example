# ===================================================================
# FDE AI Platform — Production Environment Configuration (TEMPLATE)
# ===================================================================
# Copy to deploy/.env.prod and fill in the values:
#   cp deploy/config-templates/.env.prod.example deploy/.env.prod
#
# Generate secrets:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# ===================================================================

# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=fde
POSTGRES_PASSWORD=CHANGE_ME_postgres_password_32chars
POSTGRES_DB=fde_platform

# ── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_32chars

# ── Qdrant ───────────────────────────────────────────────────────
QDRANT_API_KEY=CHANGE_ME_qdrant_api_key_32chars

# ── MinIO ────────────────────────────────────────────────────────
MINIO_ROOT_USER=fde_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password_32chars

# ── JWT ──────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_jwt_secret_64chars_hex

# ── Observability ────────────────────────────────────────────────
FDE_OTEL_ENABLED=1
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── Grafana (optional) ───────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# ── IM Platform Credentials (optional) ───────────────────────────
# WECOM_CORP_ID=ww1234567890abcdef
# WECOM_AGENT_ID=1000001
# WECOM_APP_SECRET=CHANGE_ME
# WECOM_TOKEN=CHANGE_ME
# WECOM_ENCODING_AES_KEY=CHANGE_ME

# FEISHU_APP_ID=cli_abc123
# FEISHU_APP_SECRET=CHANGE_ME
# FEISHU_VERIFICATION_TOKEN=CHANGE_ME

# DINGTALK_APP_KEY=dingabc123
# DINGTALK_APP_SECRET=CHANGE_ME
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
# DINGTALK_WEBHOOK_SECRET=CHANGE_ME

# ── Mapbox (frontend) ────────────────────────────────────────────
# VITE_MAPBOX_TOKEN=CHANGE_ME

# ── LiteLLM Gateway (P0-A / P0-B) ───────────────────────────────
# Unified model gateway: virtual keys, per-tenant budget, cost tracking.
# The master key guards the proxy admin API (/key/generate etc.).
LITELLM_MASTER_KEY=CHANGE_ME_litellm_master_key_32chars
# Dedicated Postgres for LiteLLM virtual keys (separate from fde_platform).
LITELLM_DB_PASSWORD=CHANGE_ME_litellm_db_password_32chars
# Provider keys (forwarded to the proxy; FDE backend uses its own .env too).
DEEPSEEK_API_KEY=
GLM_API_KEY=
QWEN_API_KEY=