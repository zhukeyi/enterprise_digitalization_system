# LiteLLM proxy environment template (P0-A / L-1)
# Copy to .env and fill in. .env is gitignored; .env.example is committed.
#
#   cp .env.example .env
#   # edit .env with real values, then: docker compose up -d
#
# LITELLM_MASTER_KEY is the admin key for the proxy's own API
# (/key/generate, /key/info, /key/delete). Generate one server-side:
#   openssl rand -hex 24 | sed 's/^/sk-/'
LITELLM_MASTER_KEY=sk-replace-with-generated-master-key

# Provider keys consumed by config.yaml (os.environ/...).
# Reuse the same values already present in the backend .env.
DEEPSEEK_API_KEY=
GLM_API_KEY=
QWEN_API_KEY=

# PostgreSQL connection for LiteLLM virtual-key storage (REQUIRED for
# /key/generate, /key/info, /key/delete). SQLite is NOT supported by the
# proxy for keys. Install PostgreSQL on the host and create a litellm db:
#   sudo -u postgres psql -c "CREATE ROLE litellm WITH LOGIN PASSWORD '...';"
#   sudo -u postgres psql -c "CREATE DATABASE litellm OWNER litellm;"
# The container uses host networking, so 127.0.0.1:5432 is reachable.
DATABASE_URL=postgresql://litellm:CHANGE_ME@localhost:5432/litellm
