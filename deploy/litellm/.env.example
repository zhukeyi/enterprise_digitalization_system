# LiteLLM proxy environment template (P0-A / L-1)
# Copy to .env and fill in. .env is gitignored; .env.example is committed.
#
#   cp .env.example .env
#   # edit .env with real values, then: docker compose up -d
#
# LITELLM_MASTER_KEY is the admin key for the proxy's own API
# (/key/generate, /key/info, /key/delete). Generate one server-side:
#   openssl rand -hex 24 | sed 's/^/sk-/'
LITELLM_MASTER_KEY=sk-replace-with-generated-master-key

# Provider keys consumed by config.yaml (os.environ/...).
# Reuse the same values already present in the backend .env.
DEEPSEEK_API_KEY=
GLM_API_KEY=
QWEN_API_KEY=
