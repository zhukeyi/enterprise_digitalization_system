# ===================================================================
# EditorConfig — consistent coding styles across editors
# ===================================================================

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_size = 4

[*.{ts,tsx,js,jsx,json,yaml,yml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
indent_size = 4

[Dockerfile]
indent_size = 4

[*.sh]
indent_size = 2