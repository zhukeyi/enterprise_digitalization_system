# FDE AI Platform — Environment Configuration
# Copy to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=fde
POSTGRES_PASSWORD=change-me
POSTGRES_DB=fde_platform
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Qdrant Vector DB ──────────────────────────────────────────────
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334

# ── MinIO Storage ─────────────────────────────────────────────────
MINIO_ROOT_USER=fde_admin
MINIO_ROOT_PASSWORD=change-me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Model API Keys (replace with real keys) ───────────────────────
DEEPSEEK_API_KEY=sk-your-key-here
QWEN_API_KEY=sk-your-key-here
GLM_API_KEY=your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ── Embedding Model ───────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# ── Observability ─────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── JWT / Auth ────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Debug / Mode ─────────────────────────────────────────────────
DEBUG=true
LOG_LEVEL=DEBUG

# ── Local LLM (Ollama, dev-only) ──────────────────────────────────
# Ollama OpenAI-compatible endpoint (default http://localhost:11434/v1)
# Set FDE_MAP_LLM_MODEL to enable LLM-based interpretation in MapAI.
# Uses the fde-local alias defined in deploy/litellm/config.yaml.
# Leave empty to use rule-based templates (no LLM call).
OLLAMA_BASE_URL=http://localhost:11434
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_MASTER_KEY=
FDE_MAP_LLM_MODEL=
# Set FDE_NL2SQL_LLM_MODEL to enable LLM fallback in the Analysis Agent
# NL2SQL engine. When the rule engine cannot match a query, the LLM is
# called (via LITELLM_PROXY_URL) to generate SQL, which is then validated
# by sql_safety before execution. Leave empty to disable LLM fallback
# (unmatched queries return a "not configured" result).
FDE_NL2SQL_LLM_MODEL=
# LLM call timeout in seconds (default 120; increase for slow CPU-only Ollama)
FDE_NL2SQL_LLM_TIMEOUT=120
# Set FDE_NL2SQL_USE_QDRANT=true to upgrade NL2SQL training-data retrieval
# from in-memory keyword overlap to Qdrant semantic similarity. Requires
# Qdrant + the shared BGE embedding model (already used by RAG/ingestion).
# On first use the 12 example queries are vectorised into the
# "fde_nl2sql_examples" collection. Leave "off" (default) to keep the
# zero-dependency keyword path. Falls back to keyword if Qdrant is down.
FDE_NL2SQL_USE_QDRANT=off